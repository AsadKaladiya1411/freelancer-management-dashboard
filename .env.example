PORT=5000
MONGODB_URI=mongodb://username:password@cluster-host-1:27017,cluster-host-2:27017,cluster-host-3:27017/freelancer_db?ssl=true&authSource=admin&replicaSet=your-replica-set&retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
CLIENT_URLS=http://localhost:3000,https://your-frontend.vercel.app,https://*.vercel.app
NODE_ENV=development
