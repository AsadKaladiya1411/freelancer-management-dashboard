# ============================================
# FreelanceFlow - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Server
NODE_ENV=development
PORT=5000

# ============================================
# MongoDB Atlas (REQUIRED)
# ============================================
# 1. Go to https://cloud.mongodb.com
# 2. Create a free M0 cluster
# 3. Database Access → Create a database user
# 4. Network Access → Add your IP (or 0.0.0.0/0 for dev)
# 5. Connect → Drivers → Copy connection string
# 6. Replace <password> with your database user's password
#
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=

# ============================================
# JWT Authentication (REQUIRED)
# ============================================
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ============================================
# Frontend URL (CORS)
# ============================================
# Development: http://localhost:5173
# Vercel:      https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# ============================================
# Optional Services
# ============================================
# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Upstash Redis (caching)
REDIS_URL=

# OpenAI (AI expense insights)
OPENAI_API_KEY=
